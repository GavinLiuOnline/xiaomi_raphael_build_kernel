 #include <dt-bindings/sound/qcom,q6afe.h>
+#include <linux/clk.h>
 #include <linux/module.h>
 #include <linux/platform_device.h>
 #include <linux/of_device.h>
@@ -27,9 +28,13 @@ struct sm8150_snd_data {
 	struct snd_soc_jack jack;
 	bool jack_setup;
