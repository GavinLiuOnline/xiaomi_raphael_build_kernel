 };
 
@@ -192,6 +197,58 @@ static int sm8150_tdm_snd_hw_params(struct snd_pcm_substream *substream,
 	return ret;
 }
 
+/* TFA9874 on QUAT_MI2S_RX: standard I2S, S24_LE, 48kHz, 2ch */
+static int sm8150_mi2s_snd_hw_params(struct snd_pcm_substream *substream,
+				     struct snd_pcm_hw_params *params)
+{
+	struct snd_soc_pcm_runtime *rtd = snd_soc_substream_to_rtd(substream);
+	struct snd_soc_dai *codec_dai;
+	int ret, j;
+
+	for_each_rtd_codec_dais(rtd, j, codec_dai) {
+		ret = snd_soc_dai_set_sysclk(codec_dai, Q6AFE_LPASS_CLK_ID_QUAD_MI2S_IBIT,
+					     12288000, SND_SOC_CLOCK_OUT);
+		if (ret < 0)
+			dev_info(codec_dai->dev, "set_sysclk not supported (%d)\n", ret);
+	}
+
+	return 0;
+}
+
+static int sm8150_vote_quat_mi2s_clks(struct snd_soc_dai *cpu_dai,
+				      unsigned int freq)
+{
+	int ret;
+
+	ret = snd_soc_dai_set_sysclk(cpu_dai, Q6AFE_LPASS_CLK_ID_QUAD_MI2S_IBIT,
+				     freq, SNDRV_PCM_STREAM_PLAYBACK);
+	if (ret < 0) {
+		dev_err(cpu_dai->dev, "QUAD MI2S IBIT %u Hz failed: %d\n",
+			freq, ret);
+		return ret;
+	}
+
+	ret = snd_soc_dai_set_sysclk(cpu_dai, Q6AFE_LPASS_CLK_ID_QUAD_MI2S_EBIT,
+				     freq, SNDRV_PCM_STREAM_PLAYBACK);
+	if (ret < 0) {
+		dev_err(cpu_dai->dev, "QUAD MI2S EBIT %u Hz failed: %d\n",
+			freq, ret);
+		return ret;
+	}
+
+	ret = snd_soc_dai_set_sysclk(cpu_dai, LPAIF_BIT_CLK,
+				     freq, SNDRV_PCM_STREAM_PLAYBACK);
+	if (ret < 0) {
+		dev_err(cpu_dai->dev, "QUAD MI2S LPAIF_BIT_CLK %u Hz failed: %d\n",
+			freq, ret);
+		return ret;
+	}
+
+	dev_info(cpu_dai->dev, "QUAD MI2S clocks %s at %u Hz\n",
+		 freq ? "ON" : "OFF", freq);
+	return 0;
+}
+
 static int sm8150_snd_hw_params(struct snd_pcm_substream *substream,
 					struct snd_pcm_hw_params *params)
 {
@@ -200,6 +257,9 @@ static int sm8150_snd_hw_params(struct snd_pcm_substream *substream,
 	int ret = 0;
 
 	switch (cpu_dai->id) {
+	case QUATERNARY_MI2S_RX:
+		ret = sm8150_mi2s_snd_hw_params(substream, params);
+		break;
 	case QUATERNARY_TDM_RX_0:
 	case QUATERNARY_TDM_TX_0:
 		ret = sm8150_tdm_snd_hw_params(substream, params);
@@ -306,6 +366,23 @@ static int sm8150_snd_startup(struct snd_pcm_substream *substream)
 	struct snd_soc_dai *codec_dai = snd_soc_rtd_to_codec(rtd, 0);
 
 	switch (cpu_dai->id) {
+	case QUATERNARY_MI2S_RX: {
+		unsigned int bclk = 12288000;
+		codec_dai_fmt |= SND_SOC_DAIFMT_NB_NF | SND_SOC_DAIFMT_I2S;
+		if (++(data->quat_mi2s_clk_count) == 1) {
+			sm8150_vote_quat_mi2s_clks(cpu_dai, bclk);
+			if (data->lpass_macro && !data->lpass_macro_enabled) {
+				int cret = clk_prepare_enable(data->lpass_macro);
+				if (!cret) {
+					data->lpass_macro_enabled = true;
+					data->lpass_macro_count = 1;
+				}
+			}
+		}
+		snd_soc_dai_set_fmt(cpu_dai, fmt);
+		snd_soc_dai_set_fmt(codec_dai, codec_dai_fmt);
+		break;
+	}
 	case QUATERNARY_TDM_RX_0:
 		codec_dai_fmt |= SND_SOC_DAIFMT_NB_NF | SND_SOC_DAIFMT_DSP_A;
 		if (++(data->quat_tdm_clk_count) == 1) {
@@ -333,6 +410,17 @@ static void sm8150_snd_shutdown(struct snd_pcm_substream *substream)
 	struct snd_soc_dai *cpu_dai = snd_soc_rtd_to_cpu(rtd, 0);
 
 	switch (cpu_dai->id) {
+	case QUATERNARY_MI2S_RX:
+		if (substream->stream == SNDRV_PCM_STREAM_PLAYBACK) {
+			if (data->quat_mi2s_clk_count > 0 &&
+			    --(data->quat_mi2s_clk_count) == 0) {
+				sm8150_vote_quat_mi2s_clks(cpu_dai, 0);
+			}
+			if (data->lpass_macro_count > 0 &&
+			    --(data->lpass_macro_count) == 0)
+				clk_disable_unprepare(data->lpass_macro);
+		}
+		break;
 	case QUATERNARY_TDM_RX_0:
 	case QUATERNARY_TDM_TX_0:
 		if (--(data->quat_tdm_clk_count) == 0) {
@@ -342,7 +430,6 @@ static void sm8150_snd_shutdown(struct snd_pcm_substream *substream)
 		}
 		break;
 	case SLIMBUS_0_RX...SLIMBUS_6_TX:
-	case QUATERNARY_MI2S_RX:
 		break;
 	default:
 		pr_err("%s: invalid dai id 0x%x\n", __func__, cpu_dai->id);
@@ -454,6 +541,13 @@ static int sm8150_platform_probe(struct platform_device *pdev)
 	data->card = card;
 	snd_soc_card_set_drvdata(card, data);
 
+	data->lpass_macro = devm_clk_get(dev, "lpass_macro");
+	if (IS_ERR(data->lpass_macro)) {
+		dev_info(dev, "lpass_macro clock not found (%ld)\n",
+			 PTR_ERR(data->lpass_macro));
+		data->lpass_macro = NULL;
+	}
+
 	sm8150_add_be_ops(card);
 	return devm_snd_soc_register_card(dev, card);
 }
