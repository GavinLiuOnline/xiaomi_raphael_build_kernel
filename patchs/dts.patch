diff --git a/arch/arm64/boot/dts/qcom/sm8150-xiaomi-raphael.dts b/arch/arm64/boot/dts/qcom/sm8150-xiaomi-raphael.dts
index 04646b389..2e9e535f0 100644
--- a/arch/arm64/boot/dts/qcom/sm8150-xiaomi-raphael.dts
+++ b/arch/arm64/boot/dts/qcom/sm8150-xiaomi-raphael.dts
@@ -1181,3 +1181,91 @@ &wifi {
 
 	status = "okay";
 };
+
+&remoteproc_adsp {
+	status = "okay";
+	firmware-name = "qcom/sm8150/Xiaomi/raphael/adsp.mbn";
+};
+
+&remoteproc_cdsp {
+	status = "okay";
+	firmware-name = "qcom/sm8150/Xiaomi/raphael/cdsp.mbn";
+};
+
+&remoteproc_mpss {
+	status = "okay";
+	firmware-name = "qcom/sm8150/Xiaomi/raphael/modem.mdt";
+};
+
+&remoteproc_slpi {
+	status = "okay";
+	firmware-name = "qcom/sm8150/Xiaomi/raphael/slpi_rp.mdt";
+};
+
+&q6afedai {
+	dai@72 {
+		reg = <72>;
+		qcom,tdm-sync-mode = <1>;
+		qcom,tdm-sync-src = <1>;
+		qcom,tdm-data-out = <0>;
+		qcom,tdm-invert-sync = <1>;
+		qcom,tdm-data-delay = <1>;
+		qcom,tdm-data-align = <0>;
+	};
+};
+
+&q6asmdai {
+	dai@0 {
+		reg = <0>;
+	};
+	dai@1 {
+		reg = <1>;
+	};
+};
+
+&qupv3_id_0 {
+	status = "okay";
+};
+
+&i2c1 {
+	status = "okay";
+	tfa9874: audio-codec@34 {
+		compatible = "nxp,tfa9874";
+		reg = <0x34>;
+		#sound-dai-cells = <0>;
+		vddd-supply = <&vreg_l7a_1p8>;
+		vdda-supply = <&vreg_l10c_3p3>;
+		reset-gpios = <&tlmm 59 GPIO_ACTIVE_HIGH>;
+		interrupt-parent = <&tlmm>;
+		interrupts = <141 IRQ_TYPE_LEVEL_LOW>;
+		status = "okay";
+	};
+};
+
+&sound {
+	compatible = "qcom,sm8150-sndcard";
+	model = "xiaomi-raphael";
+	clocks = <&q6afecc 102 0>,
+		 <&q6afecc 103 0>;
+	clock-names = "lpass_macro", "lpass_dcodec";
+	audio-routing = "HiFi Playback", "Quaternary TDM0 Playback", "Speaker", "HiFi Playback";
+	mm1-dai-link {
+		link-name = "MultiMedia1";
+		cpu {
+			sound-dai = <&q6asmdai 0>;
+		};
+	};
+	primary-tdm-dai-link {
+		no-pcm;
+		link-name = "Speaker Playback";
+		cpu {
+			sound-dai = <&q6afedai 72>;
+		};
+		platform {
+			sound-dai = <&q6routing>;
+		};
+		codec {
+			sound-dai = <&tfa9874>;
+		};
+	};
+};
