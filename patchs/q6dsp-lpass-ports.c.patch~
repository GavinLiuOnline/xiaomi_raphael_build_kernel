+	regmap_write(rmap, R0F_KEY1_PROT, 0x5a6b);
+	regmap_read(rmap, 0xFB, &fb_val);
+	xor_val = (fb_val ^ 0x005a) & 0xffff;
+	regmap_write(rmap, RA0_KEY2_PROT, xor_val);
+	/* key2(tfa, 0): read FB, clear bit 6, write A0 */
+	regmap_read(rmap, 0xFB, &fb_val);
+	regmap_write(rmap, RA0_KEY2_PROT, fb_val & ~0x0040);
+
+	/* Per-revision registers for TFA9874 rev 0x0c74 (from NXP ref) */
+	regmap_write(rmap, R02_SYS_CTRL2, 0x22c8);
