diff --git a/sound/soc/qcom/qdsp6/q6afe-dai.c b/sound/soc/qcom/qdsp6/q6afe-dai.c
index 0f47aadaa..550fefe9b 100644
--- a/sound/soc/qcom/qdsp6/q6afe-dai.c
