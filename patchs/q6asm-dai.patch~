 }
@@ -376,6 +392,7 @@ static void q6afe_dai_shutdown(struct snd_pcm_substream *substream,
 	if (!dai_data->is_port_started[dai->id])
 		return;
 
+	dev_info(dai->dev, "TDM shutdown: dai=0x%x\n", dai->id);
 	rc = q6afe_port_stop(dai_data->port[dai->id]);
 	if (rc < 0)
 		dev_err(dai->dev, "fail to close AFE port (%d)\n", rc);
@@ -420,9 +437,16 @@ static int q6afe_dai_prepare(struct snd_pcm_substream *substream,
 		}
 		break;
 	case PRIMARY_TDM_RX_0 ... QUINARY_TDM_TX_7:
+	{
+		struct q6afe_tdm_cfg *tdm = &dai_data->port_config[dai->id].tdm;
+		dev_info(dai->dev, "TDM prepare: dai=0x%x slots=%d slot_width=%d slot_mask=0x%x ch=%d rate=%d width=%d\n",
+			 dai->id, tdm->nslots_per_frame, tdm->slot_width,
+			 tdm->slot_mask, tdm->num_channels,
+			 tdm->sample_rate, tdm->bit_width);
 		q6afe_tdm_port_prepare(dai_data->port[dai->id],
