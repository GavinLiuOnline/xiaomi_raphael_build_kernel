+			 dai->id, tdm->nslots_per_frame, tdm->slot_width, tdm->slot_mask);
 		break;
 	default:
 		dev_err(dai->dev, "%s: invalid dai id 0x%x\n",
@@ -255,6 +257,10 @@ static int q6tdm_set_channel_map(struct snd_soc_dai *dai,
 			tdm->num_channels = rx_num;
 		}
 
+		dev_info(dai->dev, "TDM chmap: dai=0x%x num_ch=%d ch0=%d ch1=%d ch2=%d ch3=%d\n",
+			 dai->id, tdm->num_channels,
+			 tdm->ch_mapping[0], tdm->ch_mapping[1],
+			 tdm->ch_mapping[2], tdm->ch_mapping[3]);
 		break;
 	default:
 		dev_err(dai->dev, "%s: invalid dai id 0x%x\n",
@@ -278,6 +284,16 @@ static int q6tdm_hw_params(struct snd_pcm_substream *substream,
 	tdm->data_align_type = dai_data->priv[dai->id].data_align;
 	tdm->sync_src = dai_data->priv[dai->id].sync_src;
 	tdm->sync_mode = dai_data->priv[dai->id].sync_mode;
