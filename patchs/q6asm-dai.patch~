 	}
 	dai_data->is_port_started[dai->id] = true;
+	dev_info(dai->dev, "AFE port start: dai=0x%x started=%d\n",
+		 dai->id,
+		 dai_data->is_port_started[dai->id]);
 
 	return 0;
 }
