+	tdm->data_format = 0; /* AFE_LINEAR_PCM_DATA */
+
+	dev_info(dai->dev, "TDM hw_params: dai=0x%x bit_width=%d rate=%d ch=%d align=%d sync_src=%d sync_mode=%d ctrl_out=%d inv=%d delay=%d\n",
